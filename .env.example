# bizforge — Environment Configuration
# Copy this file to .env and fill in your values.

# Companies House API Key
# Apply: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Company Details (used in contract/policy templates)
COMPANY_NAME=
COMPANY_NUMBER=
COMPANY_ADDRESS=
COMPANY_REGISTERED_ADDRESS=
COMPANY_VAT_NUMBER=
COMPANY_EMAIL=
COMPANY_WEBSITE=
COMPANY_SIC_CODE=
COMPANY_DIRECTOR_NAME=

# Bank Details
BANK_NAME=
BANK_SORT_CODE=
BANK_ACCOUNT_NUMBER=

# OpenCode Go API Key (for AI advisor, document enhancement, test generation)
# Leave blank to auto-read from ~/.local/share/opencode/auth.json
# Override with: LLM_ENDPOINT, LLM_MODEL
OPENCODE_GO_API_KEY=

# Insurance
PI_INSURANCE_PROVIDER=
PI_INSURANCE_EXPIRY=
PI_INSURANCE_POLICY_NUMBER=

# Calendar Deadlines (used by npm run calendar + npm run dashboard)
# Format: YYYY-MM-DD
COMPANY_INCORPORATION_DATE=   # For computing Confirmation Statement, CT deadlines
ICO_REGISTRATION_DATE=        # For computing ICO renewal deadline
